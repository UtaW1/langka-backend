meta {
  name: update_inventory
  type: http
  seq: 43
}

patch {
  url: http://localhost:4000/api/admin/inventories/{{id}}
  body: multipartForm
  auth: none
}

body:multipart-form {
  name: Milk
  note: Fridge stock updated
  inventory_image: @file(/home/kul/Downloads/avatar-image.jpg)
}

vars:pre-request {
  id: 1
}
